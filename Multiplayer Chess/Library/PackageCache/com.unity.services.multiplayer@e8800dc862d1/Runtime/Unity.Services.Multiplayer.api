        public PublishIPAddress PublishIp { get; }
        public DirectNetworkOptions() {}
        public DirectNetworkOptions(ushort port) {}
        public DirectNetworkOptions(ListenIPAddress listenIp, PublishIPAddress publishIp, ushort port) {}
    }

    public enum FilterField
    {
        MaxPlayers = 0,
        AvailableSlots = 1,
        Name = 2,
        Created = 3,
        LastUpdated = 4,
        StringIndex1 = 5,
        StringIndex2 = 6,
        StringIndex3 = 7,
        StringIndex4 = 8,
        StringIndex5 = 9,
        NumberIndex1 = 10,
        NumberIndex2 = 11,
        NumberIndex3 = 12,
        NumberIndex4 = 13,
        NumberIndex5 = 14,
        IsLocked = 15,
        HasPassword = 16,
    }

    public enum FilterOperation
    {
        Contains = 0,
        Equal = 1,
        NotEqual = 2,
        Less = 3,
        LessOrEqual = 4,
        Greater = 5,
        GreaterOrEqual = 6,
    }

    public class FilterOption
    {
        public FilterField Field { get; }
        public FilterOperation Operation { get; }
        public string Value { get; }
        public FilterOption(FilterField field, string value, FilterOperation operation) {}
    }

    public interface IClientSessionNetwork
    {
        public event System.Action<SessionError> MigrationFailed;
        public event System.Action<SessionError> StartFailed;
        public event System.Action<NetworkState> StateChanged;
        public event System.Action<SessionError> StopFailed;
        public INetworkHandler NetworkHandler { get; set; }
        public NetworkState State { get; }
    }

    public interface IHostSession : ISession
    {
        public string Host { get; set; }
        public bool IsLocked { get; set; }
        public bool IsPrivate { get; set; }
        public string Name { get; set; }
        public IHostSessionNetwork Network { get; }
        public string Password { set; }
        public System.Collections.Generic.IReadOnlyList<IPlayer> Players { get; }
        public System.Threading.Tasks.Task DeleteAsync();
        public System.Threading.Tasks.Task<SessionMigrationData> GetHostMigrationDataAsync(System.TimeSpan timeout);
        public IPlayer GetPlayer(string playerId);
        public System.Threading.Tasks.Task RemovePlayerAsync(string playerId);
        public System.Threading.Tasks.Task SavePlayerDataAsync(string playerId);
        public System.Threading.Tasks.Task SavePropertiesAsync();
        public System.Threading.Tasks.Task SetHostMigrationDataAsync(byte[] data, System.TimeSpan timeout);
        public void SetProperties(System.Collections.Generic.Dictionary<string, SessionProperty> properties);
        public void SetProperty(string key, SessionProperty property);
    }

    public interface IHostSessionNetwork
    {
        public event System.Action<SessionError> MigrationFailed;
        public event System.Action<SessionError> StartFailed;
        public event System.Action<NetworkState> StateChanged;
        public event System.Action<SessionError> StopFailed;
        public INetworkHandler NetworkHandler { get; set; }
        public NetworkState State { get; }
        public System.Threading.Tasks.Task StartDirectNetworkAsync(DirectNetworkOptions networkOptions);
        public System.Threading.Tasks.Task StartDistributedAuthorityNetworkAsync(RelayNetworkOptions networkOptions);
        public System.Threading.Tasks.Task StartRelayNetworkAsync(RelayNetworkOptions networkOptions);
        public System.Threading.Tasks.Task StopNetworkAsync();
    }

    public interface IIpValidator
    {
        public bool IsValidIPAddress(string ip);
        public bool TryParseIPAddress(string ip, out NetworkEndpointAddress endpoint);
    }

    public interface IMigrationDataHandler
    {
        public void Apply(byte[] migrationData);
        public byte[] Generate();
    }

    public interface IMultiplayerService
    {
        public event System.Action<AddingSessionOptions, SessionException> AddingSessionFailed;
        public event System.Action<AddingSessionOptions> AddingSessionStarted;
        public event System.Action<ISession> SessionAdded;
        public event System.Action<ISession> SessionRemoved;
        public System.Collections.Generic.IReadOnlyDictionary<string, ISession> Sessions { get; }
        public System.Threading.Tasks.Task<ISession> CreateOrJoinSessionAsync(string sessionId, SessionOptions sessionOptions);
